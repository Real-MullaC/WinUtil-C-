<UserControl x:Class="WinUtil.Views.Tweaks"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
            <Button Content="Standard" Width="85" Height="28" Margin="4,0" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Content="Minimal" Width="85" Height="28" Margin="4,0" Style="{StaticResource RoundedButtonStyle}"/>
            <Button Content="Clear" Width="85" Height="28" Margin="4,0" Style="{StaticResource RoundedButtonStyle}" Click="ClearTweaks_Click"/>
            <Button Content="Get Installed" Width="110" Height="28" Margin="15,0,0,0" Style="{StaticResource BlueRoundedButtonStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="4" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,15">
            <TextBlock Text="Recommended Selections" Foreground="#CCCCCC" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                <StackPanel>
                    <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Essential Tweaks" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                            <UniformGrid Columns="2">
                                <ItemsControl ItemsSource="{Binding EssentialTweaksLeft}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Content}" Foreground="#CCCCCC" Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding EssentialTweaksRight}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Content}" Foreground="#CCCCCC" Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Advanced Tweaks - CAUTION" Foreground="#FF4444" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                            <UniformGrid Columns="2">
                                <ItemsControl ItemsSource="{Binding AdvancedTweaksLeft}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Content}" Foreground="#CCCCCC" Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding AdvancedTweaksRight}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Content}" Foreground="#CCCCCC" Margin="0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                    <StackPanel>
                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Customize Preferences" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                <ItemsControl ItemsSource="{Binding PreferenceTweaks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding Content}" Foreground="#CCCCCC" Margin="0,5"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Background="#1A1A1A" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Padding="20" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Performance Plans" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                <Button Content="Add and Activate Ultimate Performance Profile" Height="32" Margin="0,0,0,8" Style="{StaticResource RoundedButtonStyle}" Click="AddPerformancePlan_Click"/>
                                <Button Content="Remove Ultimate Performance Profile" Height="32" Style="{StaticResource RoundedButtonStyle}" Click="RemovePerformancePlan_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Run Tweaks" Height="42" Margin="0,0,5,0" Style="{StaticResource BlueRoundedButtonStyle}" FontWeight="Bold" FontSize="14" Click="ApplyTweaks_Click"/>
                    <Button Grid.Column="1" Content="Undo Selected Tweaks" Height="42" Margin="5,0,0,0" Style="{StaticResource RoundedButtonStyle}" FontSize="14" Click="UndoTweaks_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>