<Window x:Class="WinUtil.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinUtil.Views"
        Title="Windows 11 Utility" Width="1150" Height="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterScreen">

    <Border Background="#0D0D0D" CornerRadius="12" BorderBrush="#252525" BorderThickness="1">
        <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#141414">
                            <Grid>
                                <TextBlock Text="Windows 11 Utility" Foreground="White" VerticalAlignment="Center" Margin="25,0" FontSize="16" FontWeight="Bold"/>
                                <StackPanel IsItemsHost="True" Orientation="Horizontal" HorizontalAlignment="Center"/>
                                <Button Content="" Click="Close_Click" HorizontalAlignment="Right" Width="45" Background="Transparent" Foreground="White" BorderThickness="0" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="10">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem x:Name="InstallTab" Header="Install" Style="{StaticResource NavTabStyle}">
                <views:Install />
            </TabItem>

            <TabItem Header="Tweaks" Style="{StaticResource NavTabStyle}">
                <views:Tweaks />
            </TabItem>

            <TabItem Header="Config" Style="{StaticResource NavTabStyle}"/>
            <TabItem Header="Updates" Style="{StaticResource NavTabStyle}"/>
        </TabControl>
    </Border>
</Window>