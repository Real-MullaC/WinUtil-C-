<Window x:Class="WinUtil.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinUtil"
        mc:Ignorable="d"
        Title="Windows 11 Utility" Height="650" Width="1000"
        Background="#1F1F1F" Foreground="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="30,20,30,10">
            <StackPanel>
                <TextBlock Text="Windows 11 Utility" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Open Source Community Tool - Built with .NET 10" FontSize="13" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="20,0,20,20">

            <TabItem Header="Install">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <Border Padding="10">
                        <ItemsControl ItemsSource="{Binding Apps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D2D" 
                                            CornerRadius="8" 
                                            Margin="10" 
                                            Padding="16" 
                                            BorderBrush="#3F3F3F" 
                                            BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <Image Source="{Binding IconPath}" Width="48" Height="48" 
                                                       DockPanel.Dock="Left" Margin="0,0,12,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Foreground="White"/>
                                                    <TextBlock Text="{Binding AppId}" FontSize="11" Foreground="#888888"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <Grid Margin="0,20,0,0">
                                                <Button Content="Install" 
                                                        Click="InstallButton_Click"
                                                        Visibility="{Binding ButtonVisibility}"
                                                        Background="#0078D4" Foreground="White" 
                                                        FontWeight="SemiBold" BorderThickness="0"
                                                        Height="35" Cursor="Hand"/>

                                                <StackPanel Visibility="{Binding ProgressVisibility}">
                                                    <TextBlock Text="Installing..." FontSize="11" Foreground="#0078D4" Margin="0,0,0,6"/>
                                                    <ProgressBar Value="{Binding InstallProgress}" 
                                                                 Height="6" 
                                                                 IsIndeterminate="{Binding IsIndeterminate}"
                                                                 Background="#3F3F3F" Foreground="#0078D4"
                                                                 BorderThickness="0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tweaks">
                <Border Padding="20">
                    <TextBlock Text="Tweaks coming soon..." Foreground="Gray"/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>